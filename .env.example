# ─────────────────────────────────────────────────────────────────
# Environment variables for The Hormone Method
#
# Copy this file to .env.local for local development. In production,
# set these in Vercel → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# ─── REQUIRED FOR THE REGISTRATION EMAIL TO ACTUALLY SEND ───────
# Grab a free key at https://resend.com → API keys.
# Until this is set, /api/register returns 503 (but still logs the
# submission to Vercel function logs so nothing is lost).
RESEND_API_KEY=

# Sender address. Defaults to Resend's sandbox sender which works
# without domain verification — good enough for MVP. Swap to
# coachkai@shilpamethod.com once you verify shilpamethod.com in Resend.
EMAIL_FROM="Coach Kai <onboarding@resend.dev>"

# Where signup notifications land. Defaults to abhinavkej@gmail.com.
EMAIL_OPS_NOTIFICATION=abhinavkej@gmail.com

# Where registrants' replies go. Defaults to hello@shilpamethod.com.
EMAIL_REPLY_TO=hello@shilpamethod.com

# ─── FOR FUTURE WORK (not required today) ───────────────────────
# See HANDOFF.md for the full list of services needed to unlock the
# auth-gated member area, Stripe checkout, Coach Kai AI on WhatsApp,
# and Google Meet live sessions.

# DATABASE_URL=
# AUTH_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_USD=
# STRIPE_PRICE_ID_INR=
# ANTHROPIC_API_KEY=
# BLOB_READ_WRITE_TOKEN=
# CRON_SECRET=
# WHATSAPP_ACCOUNT_SID=
# WHATSAPP_AUTH_TOKEN=
# WHATSAPP_FROM_NUMBER=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
